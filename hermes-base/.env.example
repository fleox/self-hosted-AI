# ─────────────────────────────────────────────────────────────────────────────
# hermes-tech — Environment template
# Copy to .env and fill in your values before running.
# ─────────────────────────────────────────────────────────────────────────────

# Project / Traefik
PROJECT_NAME=hermes-tech
APP_FQDN=hermes-tech.local
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=http

# OpenAI-compatible endpoint of your Gemma 4 production backend
MODEL_BASE_URL=http://141.94.35.54:8000/v1

# Model name as served by the backend (must match what the backend expects)
MODEL_NAME=my-custom-model

# API key for the backend (use "no-key" for unauthenticated internal endpoints)
MODEL_API_KEY=my-token

# Context window — Hermes hard-minimum is 64000
CONTEXT_LENGTH=64000

# Max output tokens (≤ CONTEXT_LENGTH / 2 recommended)
MAX_TOKENS=32000

HERMES_WEBUI_HOST="0.0.0.0"
HERMES_WEBUI_PORT="8787"
HERMES_WEBUI_STATE_DIR="/home/hermeswebui/.hermes/webui"
HERMES_SKIP_CONFIG_MIGRATION="1"
HERMES_WEBUI_SKIP_ONBOARDING="1"
HERMES_SKIP_CHMOD="1"

# ─────────────────────────────────────────────────────────────────────────────
# WebUI settings
# ─────────────────────────────────────────────────────────────────────────────

# Password to protect the WebUI — REQUIRED for any public-facing deployment
HERMES_WEBUI_PASSWORD=changeme

# Host UID/GID for volume ownership (run `id -u` / `id -g` on the host)
UID=1000
GID=1000


